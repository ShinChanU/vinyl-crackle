{
  "name": "vinyl-crackle",
  "version": "0.1.0",
  "private": true,
  "description": "Add vinyl crackle (surface noise) to any website's audio",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "package": "cd dist && zip -r ../vinyl-crackle.zip . && cd .."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "latest",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.4",
    "esbuild": "latest",
    "jsdom": "^29.0.2",
    "typescript": "latest",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
